
# The port your Express backend runs on locally
PORT=5000

# Defines the environment (development, test, or production)
NODE_ENV="development"

# Replace with your local Postgres credentials or your hosted DB URL (e.g., Supabase, Neon)
DATABASE_URL="postgresql://postgres:localpassword@localhost:5432/vitalslog?schema=public"

# Secret key used to sign JWTs or session cookies. 
AUTH_SECRET="super-secret-development-key-do-not-use-in-prod"

# How long until a nurse/admin session expires
JWT_EXPIRES_IN="8h"